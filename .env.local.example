# WhatsApp Cloud API Configuration for this site
RBOH_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
RBOH_WHATSAPP_ACCESS_TOKEN=your_access_token_here
RBOH_WHATSAPP_VERIFY_TOKEN=your_custom_verification_token_here
RBOH_WHATSAPP_API_VERSION=v19.0
RBOH_WHATSAPP_SEND_MODE=worker
RBOH_WHATSAPP_CLIENT_ID=rboh-whatsapp-worker
# Optional worker file paths on VPS
# RBOH_WHATSAPP_AUTH_DIR=/var/www/rboh/whatsapp-worker/.wwebjs_auth
# RBOH_WHATSAPP_STATUS_FILE_PATH=/var/www/rboh/whatsapp-worker/status.json
# RBOH_WHATSAPP_QR_IMAGE_PATH=/var/www/rboh/whatsapp-worker/current-qr.txt

# Optional fallback names supported for backward compatibility
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# WHATSAPP_ACCESS_TOKEN=your_access_token_here
# WHATSAPP_VERIFY_TOKEN=your_custom_verification_token_here
# WHATSAPP_API_VERSION=v19.0

# Database (Supabase)
NEXT_PUBLIC_RBOH_SUPABASE_URL=your_rboh_supabase_url
NEXT_PUBLIC_RBOH_SUPABASE_PUBLISHABLE_KEY=your_rboh_supabase_publishable_key
RBOH_SUPABASE_SERVICE_ROLE_KEY=your_rboh_supabase_service_role_key

# Optional fallback names supported for backward compatibility
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
